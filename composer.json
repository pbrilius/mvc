{
    "name": "oryx/mvc",
    "description": "Lightweight MVC framework for rapid prototyping - A librarian package built on PHP League ecosystem",
    "type": "library",
    "license": "BSD-Source-Code",
    "keywords": ["mvc", "framework", "php", "league", "prototyping", "web", "oryx"],
    "homepage": "https://github.com/pbrilius/mvc",
    "support": {
        "issues": "https://github.com/pbrilius/mvc/issues",
        "source": "https://github.com/pbrilius/mvc"
    },
    "authors": [
        {
            "name": "Oryx MVC Team",
            "email": "team@oryx.mvc",
            "homepage": "https://github.com/pbrilius/mvc",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "psr/http-message": "^1.0|^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/container": "^1.0|^2.0",
        "guzzlehttp/psr7": "^2.0",
        "league/route": "^5.0",
        "league/container": "^3.0|^4.0",
        "league/plates": "^3.0|^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Prototype\\Mvc\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Prototype\\Mvc\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=8"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
